# ESLint 10 and eslint-plugin-jsx-a11y's peer ranges don't agree, so npm's
# automatic peer-dependency resolution fails. legacy-peer-deps restores npm 6
# behavior (install what the lockfile says, don't reconcile peers). This is the
# single home for the flag that used to be duplicated as `npm ci
# --legacy-peer-deps` in api/Dockerfile and the mise install-app task; npm reads
# it everywhere (the Nix importNpmLock build, local installs, and CI).
legacy-peer-deps=true
